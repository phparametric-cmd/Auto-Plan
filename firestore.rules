rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - Owner's user ID
    //   - name: string (required, max 100 chars) - Project name
    //   - createdAt: timestamp (required, immutable) - Creation time
    //   - updatedAt: timestamp (required) - Last update time
    //   - houseData: string (required, max 1MB) - JSON stringified HouseState
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Domain Validators
    function isValidProject() {
      return hasOnlyAllowedFields(['uid', 'name', 'createdAt', 'updatedAt', 'houseData']) &&
             hasRequiredFields(['uid', 'name', 'createdAt', 'updatedAt', 'houseData']) &&
             validStringLength('uid', 1, 128) &&
             validStringLength('name', 1, 100) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp &&
             validStringLength('houseData', 1, 1000000); // Max 1MB for JSON string
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                       isValidProject() && 
                       request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && 
                       isValidProject() && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
